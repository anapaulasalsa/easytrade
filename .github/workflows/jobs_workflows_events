name: Dynatrace SDLC Ingest

on:
  # This section replicates your "Workflow jobs" webhook settings
  workflow_job:
    types: [queued, in_progress, completed]
  
  # This section replicates your "Workflow runs" webhook settings
  workflow_run:
    types: [requested, completed]
  
  # This section replicates your "Pull requests" webhook settings
  pull_request:
    types: [opened, closed, reopened, synchronized, labeled, unlabeled]

jobs:
  send_to_dynatrace:
    runs-on: ubuntu-latest
    # Essential: prevent the bot from triggering itself in an infinite loop
    if: github.actor != 'github-actions[bot]' 
    
    steps:
      - name: Post Event to Dynatrace
        run: |
          curl -X POST "https://esa3431h.sprint.dynatracelabs.com/platform/ingest/custom/events.sdlc/github" \
          -H "Authorization: Api-Token ${{ secrets.DT_API_TOKEN }}" \
          -H "Content-Type: application/json" \
          -d @- <<EOF
          {
            "event.type": "${{ github.event_name }}",
            "event.status": "${{ github.event.action }}",
            "repository": "${{ github.repository }}",
            "workflow": "${{ github.workflow }}",
            "job_name": "${{ github.event.workflow_job.name }}",
            "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
          }
          EOF
